{
  "collectionName": "components_seo_metadata",
  "info": {
    "displayName": "Metadata",
    "description": "Reusable SEO metadata for public pages and entries"
  },
  "options": {},
  "attributes": {
    "metaTitle": {
      "type": "string",
      "maxLength": 70
    },
    "metaDescription": {
      "type": "text",
      "maxLength": 160
    },
    "canonicalUrl": {
      "type": "string"
    },
    "shareImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "noIndex": {
      "type": "boolean",
      "default": false
    }
  }
}
